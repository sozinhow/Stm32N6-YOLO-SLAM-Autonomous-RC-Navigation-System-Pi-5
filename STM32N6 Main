/**
  * @brief  Main program
  * @param  None
  * @retval None
  */
int main(void)
{
  Hardware_init();

  /*** NN Init ****************************************************************/
  uint32_t pitch_nn = 0;
  uint32_t nn_in_len = 0;
  int number_output = 0;
  float32_t *nn_out[MAX_NUMBER_OUTPUT] = {0};
  int32_t nn_out_len[MAX_NUMBER_OUTPUT] = {0};
  NeuralNetwork_init(&nn_in_len, nn_out, &number_output, nn_out_len);

  /*** Post Processing Init ***************************************************/
  app_postprocess_init(&pp_params, &NN_Instance_network);

  /*** Camera Init ************************************************************/
  /* Note: CameraPipeline_Init likely resets the camera module, which resets the IMU */
  CameraPipeline_Init(&lcd_bg_area.XSize, &lcd_bg_area.YSize, &pitch_nn);

  LCD_init();
  /* Start LCD Display camera pipe stream */
  CameraPipeline_DisplayPipe_Start(lcd_bg_buffer, CMW_MODE_CONTINUOUS);



  /*** App Loop ***************************************************************/
  HAL_UART_Receive_IT(&huart2, (uint8_t*)&uart_it_byte, 1);
  while (1)
  {
	  // --- Emergency / Hard Stop Logic ---
	if (stop_cmd_ready) {
	    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_NEUTRAL);
	    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, S_CENTER);

	      // Clear all pending flags to ensure the stop is immediate and absolute
	    stop_cmd_ready = 0;
	    motor_cmd_ready = 0;
	    steer_cmd_ready = 0;
	}

	  // --- Motor PWM Update ---
	if (motor_cmd_ready) {
	    if (!is_emergency_stop) {
	        __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, (uint32_t)motor_cmd_val);
	    }
	    motor_cmd_ready = 0;
	}

	  // --- Steering PWM Update ---
	if (steer_cmd_ready) {
	    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, (uint32_t)steer_cmd_val);
	    steer_cmd_ready = 0;
	}

	  // --- Legacy Single-Byte Command Execution ---
	if (legacy_cmd_ready) {
	    Process_Manual_Control(legacy_cmd_byte);
	    legacy_cmd_ready = 0;
	}
    CameraPipeline_IspUpdate();

    if (pitch_nn != (NN_WIDTH * NN_BPP))
    {
      /* Start NN camera single capture Snapshot */
      CameraPipeline_NNPipe_Start(dcmipp_out_nn, CMW_MODE_SNAPSHOT);
    }
    else
    {
      /* Start NN camera single capture Snapshot */
      CameraPipeline_NNPipe_Start(nn_in, CMW_MODE_SNAPSHOT);
    }

    while (cameraFrameReceived == 0) {
        // --- Emergency / Hard Stop Logic ---
        if (stop_cmd_ready) {
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_NEUTRAL);
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, S_CENTER);

            // Clear all pending flags to ensure the stop is immediate
            stop_cmd_ready = 0;
            motor_cmd_ready = 0;
            steer_cmd_ready = 0;
        }

        // --- Motor PWM Update ---
        if (motor_cmd_ready) {
            if (!is_emergency_stop) {
                __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, (uint32_t)motor_cmd_val);
            }
            motor_cmd_ready = 0;
        }

        // --- Steering PWM Update ---
        if (steer_cmd_ready) {
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, (uint32_t)steer_cmd_val);
            steer_cmd_ready = 0;
        }

        // --- Legacy Single-Byte Command Execution ---
        if (legacy_cmd_ready) {
            Process_Manual_Control(legacy_cmd_byte);
            legacy_cmd_ready = 0;
        }
    }
    cameraFrameReceived = 0;

    uint32_t ts[2] = { 0 };

    if (pitch_nn != (NN_WIDTH * NN_BPP))
    {
      SCB_InvalidateDCache_by_Addr(dcmipp_out_nn, sizeof(dcmipp_out_nn));
      img_crop(dcmipp_out_nn, nn_in, pitch_nn, NN_WIDTH, NN_HEIGHT, NN_BPP);
      SCB_CleanInvalidateDCache_by_Addr(nn_in, nn_in_len);
    }

    ts[0] = HAL_GetTick();
    /* run ATON inference */
    Run_Inference();
    ts[1] = HAL_GetTick();

    int32_t ret = app_postprocess_run((void **) nn_out, number_output, &pp_output, &pp_params);
    assert(ret == 0);
    /* --- 新增：YOLO 避人逻辑 --- */
    od_pp_outBuffer_t *rois = pp_output.pOutBuff;
    int found_person_this_frame = 0;

    for (int32_t i = 0; i < pp_output.nb_detect; i++)
    {
        // 类别 0 是 person, 置信度阈值建议参考 config 设为 0.35f 以上
        if (rois[i].class_index == 0 && rois[i].conf > 0.5f)
        {
            found_person_this_frame = 1;
            break;
        }
    }

    if (found_person_this_frame)
    {
        is_emergency_stop = 1;
        // 立即物理切断动力
        __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_NEUTRAL);
    }

    /* Display Results & IMU Data */
    Display_NetworkOutput(&pp_output, ts[1] - ts[0]);

    /* ========================================================== */
    /* --- MANUAL CONTROL LOGIC (Safety Override Disabled) --- */
    /* Handled via UART commands in Process_Manual_Control() */
    /* ========================================================== */

    /* Discard nn_out region (used by pp_input and pp_outputs variables) to avoid Dcache evictions during nn inference */
    for (int i = 0; i < number_output; i++)
    {
      float32_t *tmp = nn_out[i];
      SCB_InvalidateDCache_by_Addr(tmp, nn_out_len[i]);
    }
  }
}


static char uart_rx_buf[UART_RX_BUF_SIZE];
static uint8_t uart_rx_idx = 0;


/**
 * @brief  从 UART 接收字节，拼成完整命令后处理
 */
static void UART_ProcessByte(uint8_t byte)
{
    // --- 1. Line Termination Logic ---
    if (byte == '\n' || byte == '\r') {
        if (uart_rx_idx > 0) {
            uart_rx_buf[uart_rx_idx] = '\0';

            // Parse Motor Command: e.g., "M319"
            if (uart_rx_buf[0] == 'M' && uart_rx_idx > 1) {
                int val = atoi(&uart_rx_buf[1]);
                if (!is_emergency_stop && val >= M_BACK && val <= 330) {
                	__HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, (uint32_t)val);
                }
            }
            // Parse Steering Command: e.g., "S187"
            else if (uart_rx_buf[0] == 'S' && uart_rx_idx > 1) {
                int val = atoi(&uart_rx_buf[1]);
                if (val >= S_LEFT && val <= S_RIGHT) {
                	__HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, (uint32_t)val);
                }
            }
            // Parse Emergency Stop: "P"
            else if (uart_rx_buf[0] == 'P') {
            	 __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_NEUTRAL);
            	 __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, S_CENTER);
            }

            // Reset index for next message
            uart_rx_idx = 0;
        }
        return;
    }

    // --- 2. Legacy Command Bypass ---
    // If the first byte isn't a modern prefix, treat it as a single-byte legacy command
    if (uart_rx_idx == 0 && byte != 'S' && byte != 'M' && byte != 'P') {
        legacy_cmd_byte = byte;
        legacy_cmd_ready = 1;
        return;
    }

    // --- 3. Buffer Accumulation ---
    if (uart_rx_idx < UART_RX_BUF_SIZE - 1) {
        uart_rx_buf[uart_rx_idx++] = (char)byte;
    } else {
        // Buffer overflow protection
        uart_rx_idx = 0;
    }
}
/**
  * @brief  UART 接收完成中断回调
  */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
 {
     if (huart->Instance == USART2) {
         UART_ProcessByte(uart_it_byte);
         HAL_UART_Receive_IT(&huart2, (uint8_t*)&uart_it_byte, 1);
     }
 }

/**
 * @brief  Manual control logic based on ESP32 test script
 */
static void Process_Manual_Control(uint8_t cmd)
{
    if (cmd == '\n' || cmd == '\r') return;

    switch (cmd) {
        /* ================= 转向逻辑 (Steering) ================= */
        case 'a': // 左转
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, S_LEFT);
            break;
        case 'd': // 右转
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, S_RIGHT);
            break;
        case 's': // 回正
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, S_CENTER);
            break;

        /* ================= 马达逻辑 (Motor) ================= */
        case '1': // 低速
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_SPEED_1);
            break;
        case '2': // 中速
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_SPEED_2);
            break;
        case '3': // 高速
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_SPEED_3);
            break;
        case 'f': // full forward test (2.0ms)
          __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, 330);
          break;
        case 'p': // 停止
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_NEUTRAL);
            break;
        case 'b':
        	__HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_BRAKE);   // Step 1: Brake
        	HAL_Delay(200);                                           // Delay to ensure ESC sees brake

        	__HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_NEUTRAL);  // Step 2: Neutral
        	HAL_Delay(200);                                           // Delay to ensure ESC sees neutral

        	__HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_BACK);
            break;
        default:
            break;
    }
}

static void Hardware_init(void)
{
  /* 1. 基础底层启动 */
  MEMSYSCTL->MSCR |= MEMSYSCTL_MSCR_ICACTIVE_Msk;

  /* 确保切换到 HSI 初始状态以便配置 PLL */
  __HAL_RCC_CPUCLK_CONFIG(RCC_CPUCLKSOURCE_HSI);
  __HAL_RCC_SYSCLK_CONFIG(RCC_SYSCLKSOURCE_HSI);

  HAL_Init();

  /* 2. 必须先配置时钟！！！ */
  /* 这一步执行完，你的 APB 时钟才是预期的 200MHz */
  SystemClock_Config();

  /* 3. 现在初始化你的小车外设，PWM 频率才会准确 */
  MX_CarPeripherals_Init();

  /* 4. 其余性能与存储配置 */
  SCB_EnableICache();
#if defined(USE_DCACHE)
  MEMSYSCTL->MSCR |= MEMSYSCTL_MSCR_DCACTIVE_Msk;
  SCB_EnableDCache();
#endif

  NPURam_enable();
  Fuse_Programming();
  NPUCache_config();

  /* 外扩 RAM/Flash 初始化 */
  BSP_XSPI_RAM_Init(0);
  BSP_XSPI_RAM_EnableMemoryMappedMode(0);

  BSP_XSPI_NOR_Init_t NOR_Init;
  NOR_Init.InterfaceMode = BSP_XSPI_NOR_OPI_MODE;
  NOR_Init.TransferRate = BSP_XSPI_NOR_DTR_TRANSFER;
  BSP_XSPI_NOR_Init(0, &NOR_Init);
  BSP_XSPI_NOR_EnableMemoryMappedMode(0);

  Security_Config();
  IAC_Config();
  set_clk_sleep_mode();
}

/**
 * @brief  ADDED: Initialize PWM (Motors), UART (Pi 5), and I2C (IMU)
 */
static void MX_CarPeripherals_Init(void)
{
  GPIO_InitTypeDef GPIO_InitStruct = {0};

  /* --- 1. 使能所有必要的时钟 --- */
  __HAL_RCC_GPIOE_CLK_ENABLE();
  __HAL_RCC_GPIOF_CLK_ENABLE();
  __HAL_RCC_GPIOD_CLK_ENABLE();
  __HAL_RCC_GPIOC_CLK_ENABLE();
  __HAL_RCC_GPIOH_CLK_ENABLE();
  __HAL_RCC_TIM1_CLK_ENABLE();
  __HAL_RCC_USART2_CLK_ENABLE();
  __HAL_RCC_I2C1_CLK_ENABLE();

  /* --- 2. PWM 引脚设置 (PE9: 舵机, PE13: 电调) --- */
  GPIO_InitStruct.Pin = GPIO_PIN_9 | GPIO_PIN_13;
  GPIO_InitStruct.Mode = GPIO_MODE_AF_PP;
  GPIO_InitStruct.Pull = GPIO_NOPULL;
  GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_MEDIUM; // 降速以减少电磁干扰
  GPIO_InitStruct.Alternate = GPIO_AF1_TIM1;
  HAL_GPIO_Init(GPIOE, &GPIO_InitStruct);

  /* --- 3. UART2 引脚设置 (PF6: RX, PD5: TX) --- */
  GPIO_InitStruct.Mode = GPIO_MODE_AF_PP;
  GPIO_InitStruct.Pull = GPIO_PULLUP;
  GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_VERY_HIGH;
  GPIO_InitStruct.Alternate = GPIO_AF7_USART2;

  GPIO_InitStruct.Pin = GPIO_PIN_6;
  HAL_GPIO_Init(GPIOF, &GPIO_InitStruct);

  GPIO_InitStruct.Pin = GPIO_PIN_5;
  HAL_GPIO_Init(GPIOD, &GPIO_InitStruct);

  /* --- 3b. UART2 初始化 --- */
  huart2.Instance = USART2;
  huart2.Init.BaudRate = 115200;
  huart2.Init.WordLength = UART_WORDLENGTH_8B;
  huart2.Init.StopBits = UART_STOPBITS_1;
  huart2.Init.Parity = UART_PARITY_NONE;
  huart2.Init.Mode = UART_MODE_TX_RX;
  huart2.Init.HwFlowCtl = UART_HWCONTROL_NONE;
  huart2.Init.OverSampling = UART_OVERSAMPLING_16;
  if (HAL_UART_Init(&huart2) != HAL_OK) { while (1) {} }
  HAL_NVIC_SetPriority(USART2_IRQn, 5, 0);
  HAL_NVIC_EnableIRQ(USART2_IRQn);
  HAL_UART_Transmit(&huart2, (uint8_t*)"\r\n[System] UART Init OK\r\n", 25, 100);

  /* --- 4. TIM1 配置 (50Hz PWM) --- */
  /* --- 4. TIM1 配置 (修正为精准 50Hz) --- */
  htim1.Instance = TIM1;
      // 算法：200MHz / 1000 = 200,000Hz (计数频率)
  htim1.Init.Prescaler = 2000 - 1;
  htim1.Init.CounterMode = TIM_COUNTERMODE_UP;
  htim1.Init.Period = 4000 - 1;
  HAL_TIM_GenerateEvent(&htim1, TIM_EVENTSOURCE_UPDATE);
  htim1.Init.ClockDivision = TIM_CLOCKDIVISION_DIV1;
  htim1.Init.RepetitionCounter = 0;
  htim1.Init.AutoReloadPreload = TIM_AUTORELOAD_PRELOAD_ENABLE;
  if (HAL_TIM_PWM_Init(&htim1) != HAL_OK) { while (1) {} }

  TIM_OC_InitTypeDef sConfig = {0};
  sConfig.OCMode = TIM_OCMODE_PWM1;
  sConfig.OCPolarity = TIM_OCPOLARITY_HIGH;
  sConfig.OCFastMode = TIM_OCFAST_DISABLE;
  sConfig.OCIdleState = TIM_OCIDLESTATE_RESET;

  /* --- 5. 设置初始占空比 (关键：在 Start 之前配置好) --- */
  sConfig.Pulse = S_CENTER;  // 舵机中位 (15度/307)
  HAL_TIM_PWM_ConfigChannel(&htim1, &sConfig, TIM_CHANNEL_1);

  sConfig.Pulse = M_NEUTRAL; // 电调中位 (307)
  HAL_TIM_PWM_ConfigChannel(&htim1, &sConfig, TIM_CHANNEL_3);

  /* --- 6. 开启 PWM 并使能主输出 --- */
  HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
  HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3);
  __HAL_TIM_MOE_ENABLE(&htim1);

  /* FORCE RECALIBRATION: High-Low sweep to reset ESC memory */
  HAL_UART_Transmit(&huart2, (uint8_t*)"[Resetting ESC...]\r\n", 20, 100);

  __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_NEUTRAL);
  HAL_Delay(2000);

  HAL_UART_Transmit(&huart2, (uint8_t*)"[System] ESC Armed\r\n", 20, 100);


  /* --- 8. I2C1 初始化 (IMU 使用) --- */
  GPIO_InitStruct.Pin = GPIO_PIN_1;
  GPIO_InitStruct.Mode = GPIO_MODE_AF_OD;
  GPIO_InitStruct.Pull = GPIO_PULLUP;
  GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;
  GPIO_InitStruct.Alternate = GPIO_AF4_I2C1;
  HAL_GPIO_Init(GPIOC, &GPIO_InitStruct);

  GPIO_InitStruct.Pin = GPIO_PIN_9;
  HAL_GPIO_Init(GPIOH, &GPIO_InitStruct);

  hi2c1.Instance = I2C1;
  hi2c1.Init.Timing = 0x00B03FDB;
  hi2c1.Init.AddressingMode = I2C_ADDRESSINGMODE_7BIT;
  if (HAL_I2C_Init(&hi2c1) != HAL_OK) { while (1) {} }
}


static void Run_Inference(void)
{
    LL_ATON_RT_RetValues_t ll_aton_rt_ret;

    do
    {
        ll_aton_rt_ret = LL_ATON_RT_RunEpochBlock(&NN_Instance_network);

        /* Process UART commands during inference */
        if (stop_cmd_ready)
        {
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, M_NEUTRAL);
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, S_CENTER);

            stop_cmd_ready  = 0;
            motor_cmd_ready = 0;
            steer_cmd_ready = 0;
        }

        if (motor_cmd_ready)
        {
            if (!is_emergency_stop)
                __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, (uint32_t)motor_cmd_val);

            motor_cmd_ready = 0;
        }

        if (steer_cmd_ready)
        {
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, (uint32_t)steer_cmd_val);
            steer_cmd_ready = 0;
        }

        if (legacy_cmd_ready)
        {
            Process_Manual_Control(legacy_cmd_byte);
            legacy_cmd_ready = 0;
        }

        if (ll_aton_rt_ret == LL_ATON_RT_WFE)
        {
            LL_ATON_OSAL_WFE();
        }

    } while (ll_aton_rt_ret != LL_ATON_RT_DONE);

    LL_ATON_RT_Reset_Network(&NN_Instance_network);
}

static void NeuralNetwork_init(uint32_t *nnin_length, float32_t *nn_out[], int *number_output, int32_t nn_out_len[])
{
  const LL_Buffer_InfoTypeDef *nn_in_info = LL_ATON_Input_Buffers_Info(&NN_Instance_network);
  const LL_Buffer_InfoTypeDef *nn_out_info = LL_ATON_Output_Buffers_Info(&NN_Instance_network);

  // Get the input buffer address_networ
  nn_in = (uint8_t *) LL_Buffer_addr_start(&nn_in_info[0]);

  /* Count number of outputs */
  while (nn_out_info[*number_output].name != NULL)
  {
    (*number_output)++;
  }
  assert(*number_output <= MAX_NUMBER_OUTPUT);

  for (int i = 0; i < *number_output; i++)
  {
    // Get the output buffers address
    nn_out[i] = (float32_t *) LL_Buffer_addr_start(&nn_out_info[i]);
    nn_out_len[i] = LL_Buffer_len(&nn_out_info[i]);
  }

  *nnin_length = LL_Buffer_len(&nn_in_info[0]);

  LL_ATON_RT_RuntimeInit();
  LL_ATON_RT_Init_Network(&NN_Instance_network);
}

